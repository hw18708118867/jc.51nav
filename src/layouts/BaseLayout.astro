---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../utils/site.ts';

interface Props {
  title?: string;
  description?: string;
  type?: 'website' | 'article';
  darkHero?: boolean;
}
const { title, description = SITE.description, type = 'website', darkHero = false } = Astro.props;
const pageTitle = title ? `${title} | ${SITE.name}` : SITE.title;
const canonical = new URL(Astro.url.pathname, SITE.url).href;

const gaId = import.meta.env.PUBLIC_GA_ID;
const adsClient = import.meta.env.PUBLIC_ADSENSE_CLIENT;
const gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION;
---

<!doctype html>
<html lang={SITE.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />
    {
      gscVerification && (
        <meta name="google-site-verification" content={gscVerification} />
      )
    }
  </head>
  <body class:list={['flex min-h-screen flex-col', { 'has-dark-hero': darkHero }]}>
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    {
      gaId && (
        <>
          <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} />
          <script is:inline define:vars={{ gaId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() { dataLayer.push(arguments); }
            gtag('js', new Date());
            gtag('config', gaId);
          </script>
        </>
      )
    }

    {
      adsClient && (
        <script is:inline async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsClient}`} crossorigin="anonymous" />
      )
    }
  </body>
</html>
