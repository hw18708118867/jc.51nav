---
import ParticleField from './ParticleField.astro';

interface Props {
  title: string;
  subtitle?: string;
  icon?: string;
  tag?: string;
}
const { title, subtitle, icon, tag } = Astro.props;
---

<ParticleField />

<section class="page-hero">
  <div class="hero-aurora hero-aurora-1"></div>
  <div class="hero-aurora hero-aurora-2"></div>
  <div class="hero-aurora hero-aurora-3"></div>
  <div class="hero-grid"></div>
  <canvas data-particle class="pointer-events-none absolute inset-0 h-full w-full"></canvas>

  <div class="relative z-10 mx-auto max-w-7xl px-4 py-14 text-white">
    {tag && (
      <span class="mb-4 inline-block rounded-full border border-white/20 bg-white/10 px-3 py-1 text-xs font-medium backdrop-blur">
        {tag}
      </span>
    )}
    <div class="flex items-center gap-3">
      {icon && <span class="text-4xl">{icon}</span>}
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
    </div>
    {subtitle && <p class="mt-3 max-w-2xl text-sm text-slate-300 sm:text-base">{subtitle}</p>}
  </div>
</section>
