---
import { getCollection } from 'astro:content';
import { CATEGORIES, getCategory } from '../utils/site.ts';

interface Props {
  currentId?: string;
}
const { currentId } = Astro.props;

const entries = await getCollection('tutorials', ({ data }) => !data.draft);
// 按分类分组，组内按 order / pubDate 排序
const grouped = CATEGORIES.map((cat) => ({
  category: cat,
  items: entries
    .filter((e) => e.data.category === cat.slug)
    .sort((a, b) => a.data.order - b.data.order || b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
})).filter((g) => g.items.length > 0);
---

<aside class="hidden w-64 shrink-0 lg:block">
  <div class="sticky top-20 max-h-[calc(100vh-6rem)] overflow-y-auto pr-2">
    {
      grouped.map((g) => (
        <div class="mb-6">
          <a
            href={`/categories/${g.category.slug}`}
            class="mb-2 flex items-center gap-2 text-sm font-semibold text-slate-900 hover:text-brand-600"
          >
            <span>{g.category.icon}</span>
            <span>{g.category.name}</span>
          </a>
          <ul class="space-y-1 border-l border-slate-200 pl-3">
            {g.items.map((item) => (
              <li>
                <a
                  href={`/docs/${item.id}`}
                  class={`block truncate rounded px-2 py-1 text-sm transition ${
                    item.id === currentId
                      ? 'bg-brand-50 font-medium text-brand-700'
                      : 'text-slate-500 hover:bg-slate-100 hover:text-brand-600'
                  }`}
                  title={item.data.title}
                >
                  {item.data.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</aside>
