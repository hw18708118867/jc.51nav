---
import { getCollection } from 'astro:content';
import { getCategory, getSubCategory } from '../utils/site.ts';

interface Props {
  currentId?: string;
  category?: string;
  subcategory?: string;
}
const { currentId, category, subcategory } = Astro.props;

const entries = await getCollection('tutorials', ({ data }) => !data.draft);

// 当前系列：优先按「分类 + 子分类」聚合，子分类缺失时退化为按分类聚合
const series = entries
  .filter((e) =>
    subcategory
      ? e.data.category === category && e.data.subcategory === subcategory
      : e.data.category === category
  )
  .sort((a, b) => a.data.order - b.data.order || b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const seriesCat = getCategory(category ?? '');
const seriesTitle = subcategory
  ? (getSubCategory(category ?? '', subcategory)?.name ?? seriesCat?.name)
  : seriesCat?.name;

// 相关教程：排除当前系列，按更新时间取较新的若干篇
const related = entries
  .filter((e) => e.id !== currentId && e.data.category !== category)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<aside class="hidden w-64 shrink-0 lg:block">
  <div class="sticky top-20 max-h-[calc(100vh-6rem)] overflow-y-auto pr-2">
    <!-- 当前系列导航菜单 -->
    {
      series.length > 0 && (
        <nav class="mb-6">
          <p class="mb-2 flex items-center gap-2 px-2 text-xs font-semibold uppercase tracking-wider text-slate-400">
            <span>{seriesCat?.icon}</span>
            <span>{seriesTitle} · 教程目录</span>
          </p>
          <ul class="space-y-1 border-l-2 border-brand-100 pl-3">
            {series.map((item, i) => (
              <li>
                <a
                  href={`/docs/${item.id}`}
                  class={`group flex items-center gap-2 rounded px-2 py-1.5 text-sm transition ${
                    item.id === currentId
                      ? 'bg-brand-50 font-medium text-brand-700'
                      : 'text-slate-600 hover:bg-slate-100 hover:text-brand-600'
                  }`}
                  title={item.data.title}
                >
                  <span class={`text-xs tabular-nums ${item.id === currentId ? 'text-brand-400' : 'text-slate-300'}`}>
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <span class="truncate">{item.data.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }

    <!-- 相关教程 -->
    {
      related.length > 0 && (
        <div class="mb-2">
          <p class="mb-2 px-2 text-xs font-semibold uppercase tracking-wider text-slate-400">相关教程</p>
          <ul class="space-y-1">
            {related.map((item) => (
              <li>
                <a
                  href={`/docs/${item.id}`}
                  class="block truncate rounded px-2 py-1.5 text-sm text-slate-500 transition hover:bg-slate-100 hover:text-brand-600"
                  title={item.data.title}
                >
                  {item.data.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </div>
</aside>
