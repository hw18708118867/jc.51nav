---
import { SITE, CATEGORIES } from '../utils/site.ts';
const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-slate-200 bg-white">
  <div class="mx-auto grid max-w-7xl gap-8 px-4 py-12 sm:grid-cols-2 lg:grid-cols-4">
    <div>
      <div class="flex items-center gap-2 text-lg font-bold text-brand-700">
        <img src="/favicon.svg" alt="logo" class="h-7 w-7 rounded-lg" />
        <span>{SITE.name}</span>
      </div>
      <p class="mt-3 text-sm leading-relaxed text-slate-500">
        系统化、可实践的中文 IT 技术教程站，助你从入门走向精通。
      </p>
    </div>

    <div>
      <h3 class="mb-3 text-sm font-semibold text-slate-900">教程分类</h3>
      <ul class="space-y-2 text-sm text-slate-500">
        {
          CATEGORIES.map((c) => (
            <li>
              <a href={`/categories/${c.slug}`} class="transition hover:text-brand-600">
                {c.name}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h3 class="mb-3 text-sm font-semibold text-slate-900">站点导航</h3>
      <ul class="space-y-2 text-sm text-slate-500">
        <li><a href="/" class="transition hover:text-brand-600">首页</a></li>
        <li><a href="/search" class="transition hover:text-brand-600">全站搜索</a></li>
        <li><a href="/about" class="transition hover:text-brand-600">关于本站</a></li>
        <li><a href="/rss.xml" class="transition hover:text-brand-600">RSS 订阅</a></li>
      </ul>
    </div>

    <div>
      <h3 class="mb-3 text-sm font-semibold text-slate-900">友链 / 合作</h3>
      <ul class="space-y-2 text-sm text-slate-500">
        <li><a href="https://toolbox.51nav.com/" class="transition hover:text-brand-600">开发工具箱</a></li>
        <li class="text-slate-400">友链招募中…</li>
      </ul>
    </div>
  </div>

  <div class="border-t border-slate-100 py-5 text-center text-xs text-slate-400">
    <p>© {year} {SITE.name}（{SITE.shortName}）. 保留所有权利.</p>
  </div>
</footer>
