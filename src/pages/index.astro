---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import SearchBox from '../components/SearchBox.astro';
import ParticleField from '../components/ParticleField.astro';
import { SITE, CATEGORIES } from '../utils/site.ts';

const entries = await getCollection('tutorials', ({ data }) => !data.draft);
const latest = [...entries].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 9);

const categoriesWithCount = CATEGORIES.map((c) => ({
  ...c,
  count: entries.filter((e) => e.data.category === c.slug).length,
}));
---

<BaseLayout>
  <!-- 全站粒子背景（固定视口，贯穿整页） -->
  <ParticleField />

  <!-- Hero -->
  <section id="hero" class="hero-home relative overflow-hidden">
    <div class="hero-aurora hero-aurora-1"></div>
    <div class="hero-aurora hero-aurora-2"></div>
    <div class="hero-aurora hero-aurora-3"></div>
    <div class="hero-grid"></div>
    <canvas data-particle class="pointer-events-none absolute inset-0 h-full w-full"></canvas>
    <div class="relative z-10 mx-auto max-w-7xl px-4 py-24 text-center text-white">
      <img
        src="/favicon.svg"
        alt={SITE.name}
        class="mx-auto h-24 w-24 drop-shadow-[0_0_24px_rgba(59,130,246,0.55)] sm:h-28 sm:w-28"
        width="112"
        height="112"
      />
      <span class="mt-6 inline-block rounded-full border border-white/20 bg-white/10 px-3 py-1 text-xs font-medium backdrop-blur">系统化 · 可实践 · 免费</span>
      <h1 class="mt-5 text-4xl font-bold tracking-tight text-white sm:text-5xl">{SITE.name} · 从零开始，系统掌握 IT 技术</h1>
      <p class="mx-auto mt-4 max-w-2xl text-base text-slate-300 sm:text-lg">
        {SITE.description}
      </p>
      <div class="mx-auto mt-8 flex justify-center">
        <SearchBox />
      </div>
    </div>
  </section>

  <!-- 分类入口 -->
  <section class="relative mx-auto max-w-7xl px-4 py-14">
    <h2 class="mb-6 text-2xl font-bold text-slate-900">浏览分类</h2>
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
      {
        categoriesWithCount.map((c) => (
          <a
            href={`/categories/${c.slug}`}
            class="group flex flex-col items-center rounded-2xl border border-slate-200 bg-white p-6 text-center transition duration-200 hover:-translate-y-1 hover:border-brand-300 hover:shadow-lg"
          >
            <span class="text-3xl">{c.icon}</span>
            <span class="mt-3 font-semibold text-slate-900 group-hover:text-brand-600">{c.name}</span>
            <span class="mt-1 text-xs text-slate-400">{c.count} 篇教程</span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- 最新教程 -->
  <section class="mx-auto max-w-7xl px-4 pb-16">
    <div class="mb-6 flex items-end justify-between">
      <h2 class="text-2xl font-bold text-slate-900">最新教程</h2>
      <a href="/search" class="text-sm font-medium text-brand-600 hover:underline">查看全部 →</a>
    </div>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {latest.map((entry) => <ArticleCard entry={entry} />)}
    </div>
  </section>
</BaseLayout>
