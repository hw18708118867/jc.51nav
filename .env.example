# ===== Google Analytics（流量统计）=====
# 在 GitHub 仓库 Settings → Secrets and variables → Actions 中配置同名变量
# 格式示例：G-XXXXXXXXXX
PUBLIC_GA_ID=

# ===== Google AdSense（广告变现，预留）=====
# 你的发布商 ID，格式示例：ca-pub-1234567890123456
# 配置后站内广告位自动启用；留空则不加载任何广告脚本
PUBLIC_ADSENSE_CLIENT=

# ===== Giscus 评论（基于 GitHub Discussions，纯前端）=====
# 在 https://giscus.app 生成配置后填入
PUBLIC_GISCUS_REPO=           # 例如：yourname/yourrepo
PUBLIC_GISCUS_REPO_ID=        # 仓库 ID
PUBLIC_GISCUS_CATEGORY=       # 例如：Announcements
PUBLIC_GISCUS_CATEGORY_ID=    # 分类 ID
PUBLIC_GISCUS_LANG=zh-CN
